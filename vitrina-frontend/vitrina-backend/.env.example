# ============================================================
#  VITRINA EMPRESARIAL DIGITAL — Variables de entorno
#  Copia este archivo como .env y completa los valores
#  NUNCA subas .env a git
# ============================================================

# Servidor
NODE_ENV=development
PORT=3000

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=contraseña_segura_aqui
DB_NAME=vitrina_empresarial_db
DB_CONNECTION_LIMIT=10

# JWT
JWT_SECRET=tu_clave_secreta_aqui
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Archivos
UPLOAD_PATH=uploads
MAX_FILE_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# CORS — URL del frontend React
CORS_ORIGIN=http://localhost:5173

# Logs
LOG_LEVEL=debug
